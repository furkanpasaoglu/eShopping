{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "realm": "eshopping",
    "auth-server-url": "http://localhost:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/catalog/{**catch-all}" },
        "Metadata": {
          "AuthDecision": "No gateway-level auth: YARP does not support HTTP-method-based routing. Admin write endpoints (POST/PUT/DELETE) are protected by downstream Catalog API auth (RequireAdmin policy). Verified by integration tests in Phase 9."
        }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/basket/{**catch-all}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/orders/{**catch-all}" }
      },
      "stock-route": {
        "ClusterId": "stock-cluster",
        "AuthorizationPolicy": "RequireAdmin",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/stock/{**catch-all}" }
      },
      "profile-route": {
        "ClusterId": "profile-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/profile/{**catch-all}" }
      },
      "shipping-route": {
        "ClusterId": "shipping-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "per-user",
        "Match": { "Path": "/api/{version}/shipping/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": { "Address": "http://catalog-api" }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket": { "Address": "http://basket-api" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order": { "Address": "http://order-api" }
        }
      },
      "stock-cluster": {
        "Destinations": {
          "stock": { "Address": "http://stock-api" }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "profile": { "Address": "http://userprofile-api" }
        }
      },
      "shipping-cluster": {
        "Destinations": {
          "shipping": { "Address": "http://shipping-api" }
        }
      }
    }
  }
}
